{
  "name": "@tsumiki/ukiyoe",
  "version": "0.1.0",
  "description": "Babylon.js-based rendering and physics for Tsumiki",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "clean": "rm -rf dist *.tsbuildinfo",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "babylonjs",
    "rendering",
    "physics",
    "3d"
  ],
  "license": "MIT",
  "dependencies": {
    "@babylonjs/core": "^7.36.0",
    "@babylonjs/havok": "^1.3.10",
    "@tsumiki/utsutsu": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "tsdown": "^0.3.2",
    "typescript": "^5.7.2"
  }
}
